{
    "manifest_version": 3,
    "name": "BreakCat",
    "version": "0.1.0",
    "description": "Take healthy breaks with your cat companion!",
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "BreakCat"
    },
    "background": {
        "service_worker": "background/background.js"
    },
    "permissions": ["storage", "alarms", "tabs", "scripting"],
    "host_permissions": ["<all_urls>"],
    "web_accessible_resources": [
        {
            "resources": ["assets/cat/cat.svg"],
            "matches": ["<all_urls>"]
        }
    ]
}
